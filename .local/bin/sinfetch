#!/usr/bin/env bash

# sinfetch - 0xSin system fetch
# Colors: gray=primary, cyan=secondary, yellow=alert

w="\033[1;37m"   # bold gray/white  вҖ” primary
c="\033[1;36m"   # bold cyan        вҖ” secondary / labels
y="\033[1;33m"   # bold yellow      вҖ” alert / separator
d="\033[0;90m"   # dark gray        вҖ” shadow / dim
g="\033[0;37m"   # gray             вҖ” values
r="\033[0m"      # reset

# Read prompt name for user@host line
_NAME_FILE="$HOME/.config/0xSin/prompt_name"
_OXSIN_NAME="$( [[ -f ${_NAME_FILE} ]] && cat ${_NAME_FILE} || echo '0xSin' )"

function getModel()    { model="$(getprop ro.product.brand 2>/dev/null) $(getprop ro.product.model 2>/dev/null)"; }
function getCodeName() { codename="$(getprop ro.product.board 2>/dev/null)"; }
function getClient()   { client="$(getprop ro.com.google.clientidbase 2>/dev/null)"; }
function getOS()       { os="$(uname -o) $(uname -m)"; }
function getKernel()   { kernel="$(uname -r)"; }
function getShell()    { shell="$(basename $SHELL)"; }
function getUptime()   { up="$(uptime -p 2>/dev/null | sed 's/up //' || uptime | sed 's/.*up //' | cut -d',' -f1,2)"; }
function getPackages() { packages=$(dpkg-query -l 2>/dev/null | grep -c "^ii" || echo "unknown"); }
function getMemory() {
  _row="$(free --mega 2>/dev/null | grep 'Mem:')"
  memory="$(echo ${_row} | awk '{print $3}')MB / $(echo ${_row} | awk '{print $2}')MB"
}
function getDisk() {
  _row="$(df -h /data 2>/dev/null | tail -1)"
  storage="$(echo ${_row} | awk '{print $3}') / $(echo ${_row} | awk '{print $2}')  $(echo ${_row} | awk '{print $4}') free  ($(echo ${_row} | awk '{print $5}'))"
}

getModel; getCodeName; getClient; getOS; getKernel
getPackages; getShell; getUptime; getMemory; getDisk

echo ""
echo -e "${w}  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—${r}   ${d}root${r}${d}@${r}${c}${_OXSIN_NAME}${r}"
echo -e "${w}  в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘${r}"
echo -e "${w}  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘${r}   ${c}phone  ${r}${g}${model}${r}"
echo -e "${w}  в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘${r}   ${c}os     ${r}${g}${os}${r}"
echo -e "${w}  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘${r}   ${c}kernel ${r}${g}${kernel}${r}"
echo -e "${w}  в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•җв•җв•қ${r}   ${c}pkgs   ${r}${g}${packages}${r}"
echo -e "                        ${c}shell  ${r}${g}${shell}${r}"
echo -e "                        ${c}uptime ${r}${g}${up}${r}"
echo -e "                        ${c}ram    ${r}${g}${memory}${r}"
echo -e "                        ${c}disk   ${r}${g}${storage}${r}"
echo ""
echo -e "  ${d}в”Җв”Җв”Җ${r}${g}в”Җв”Җв”Җ${r}${w}в”Җв”Җв”Җ${r}${c}в”Җв”Җв”Җ${r}${y}в”Җв”Җв”Җ${r}${c}в”Җв”Җв”Җ${r}${w}в”Җв”Җв”Җ${r}"
echo ""
