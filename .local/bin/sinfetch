#!/usr/bin/env bash

# sinfetch - 0xSin system fetch

w="\033[1;37m"   # bold white
d="\033[0;90m"   # dark gray
g="\033[0;37m"   # gray
r="\033[0m"      # reset

function getModel()    { model="$(getprop ro.product.brand 2>/dev/null) $(getprop ro.product.model 2>/dev/null)"; }
function getCodeName() { codename="$(getprop ro.product.board 2>/dev/null)"; }
function getClient()   { client="$(getprop ro.com.google.clientidbase 2>/dev/null)"; }
function getOS()       { os="$(uname -o) $(uname -m)"; }
function getKernel()   { kernel="$(uname -r)"; }
function getShell()    { shell="$(basename $SHELL)"; }
function getUptime()   { up="$(uptime -p 2>/dev/null | sed 's/up //' || uptime | sed 's/.*up //' | cut -d',' -f1,2)"; }

function getPackages() {
  packages=$(dpkg-query -l 2>/dev/null | grep -c "^ii" || echo "unknown")
}

function getMemory() {
  _row="$(free --mega 2>/dev/null | grep 'Mem:')"
  _total="$(echo ${_row} | awk '{print $2}')"
  _used="$(echo ${_row} | awk '{print $3}')"
  memory="${_used}MB / ${_total}MB"
}

function getDisk() {
  _row="$(df -h /data 2>/dev/null | tail -1)"
  _used="$(echo ${_row} | awk '{print $3}')"
  _size="$(echo ${_row} | awk '{print $2}')"
  _avail="$(echo ${_row} | awk '{print $4}')"
  _pct="$(echo ${_row} | awk '{print $5}')"
  storage="${_used} / ${_size}  ${_avail} free  (${_pct})"
}

getModel; getCodeName; getClient; getOS; getKernel
getPackages; getShell; getUptime; getMemory; getDisk

echo ""
echo -e "${w}███████╗██╗███╗   ██╗${r}   ${d}${codename}${r}${g}@${r}${d}${client}${r}"
echo -e "${w}██╔════╝██║████╗  ██║${r}"
echo -e "${w}███████╗██║██╔██╗ ██║${r}   ${g}phone  ${r}${w}${model}${r}"
echo -e "${w}╚════██║██║██║╚██╗██║${r}   ${g}os     ${r}${w}${os}${r}"
echo -e "${w}███████║██║██║ ╚████║${r}   ${g}kernel ${r}${w}${kernel}${r}"
echo -e "${w}╚══════╝╚═╝╚═╝  ╚═══╝${r}   ${g}pkgs   ${r}${w}${packages}${r}"
echo -e "                      ${g}shell  ${r}${w}${shell}${r}"
echo -e "                      ${g}uptime ${r}${w}${up}${r}"
echo -e "                      ${g}ram    ${r}${w}${memory}${r}"
echo -e "                      ${g}disk   ${r}${w}${storage}${r}"
echo ""
echo -e "  ${d}───${r}${g}───${r}${w}───${r}${g}───${r}${d}───${r}${g}───${r}${w}───${r}"
echo ""
